{
  "name": "enpass-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol (MCP) server for Enpass vaults: unlock, list vaults, list and read entries, create entries. Master passwords are kept in the OS keychain and never pass through the model.",
  "type": "module",
  "bin": {
    "enpass-mcp": "src/cli.js"
  },
  "exports": {
    ".": "./src/server.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/cli.js serve",
    "serve": "node src/cli.js serve",
    "test": "node --test",
    "generate-fixtures": "node scripts/generate-fixtures.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Fabian Bitter (fabian@bitter.de)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitterdev/enpass-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "enpass",
    "password-manager",
    "sqlcipher",
    "vault",
    "claude",
    "stdio"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "better-sqlite3-multiple-ciphers": "^12.11.1",
    "zod": "^3.25.0"
  }
}
